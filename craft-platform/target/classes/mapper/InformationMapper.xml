<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.craft.mapper.InformationMapper">
    <resultMap id="InformationMap" type="com.craft.entity.Information">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="content" property="content"/>
        <result column="image" property="image"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insert" parameterType="com.craft.entity.Information" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO information (title, content, image, status, create_time)
        VALUES (#{title}, #{content}, #{image}, #{status}, #{createTime})
    </insert>

    <select id="findById" parameterType="java.lang.Long" resultMap="InformationMap">
        SELECT * FROM information WHERE id = #{id}
    </select>

    <select id="findAll" resultMap="InformationMap">
        SELECT * FROM information
    </select>

    <update id="update" parameterType="com.craft.entity.Information">
        UPDATE information
        SET title = #{title},
            content = #{content},
            image = #{image},
            status = #{status}
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM information WHERE id = #{id}
    </delete>
</mapper>