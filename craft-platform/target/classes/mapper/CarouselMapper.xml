<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.craft.mapper.CarouselMapper">
    <resultMap id="CarouselMap" type="com.craft.entity.Carousel">
        <id column="id" property="id"/>
        <result column="image" property="image"/>
        <result column="title" property="title"/>
        <result column="link" property="link"/>
        <result column="order_num" property="orderNum"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="findAll" resultMap="CarouselMap">
        SELECT * FROM carousel ORDER BY order_num ASC
    </select>

    <select id="findById" parameterType="java.lang.Long" resultMap="CarouselMap">
        SELECT * FROM carousel WHERE id = #{id}
    </select>

    <select id="findActiveCarousels" resultMap="CarouselMap">
        SELECT * FROM carousel WHERE status = 'active' ORDER BY order_num ASC
    </select>

    <insert id="insert" parameterType="com.craft.entity.Carousel">
        INSERT INTO carousel (image, title, link, order_num, status, create_time)
        VALUES (#{image}, #{title}, #{link}, #{orderNum}, #{status}, NOW())
    </insert>

    <update id="update" parameterType="com.craft.entity.Carousel">
        UPDATE carousel
        SET image = #{image}, title = #{title}, link = #{link}, 
            order_num = #{orderNum}, status = #{status}
        WHERE id = #{id}
    </update>

    <delete id="delete" parameterType="java.lang.Long">
        DELETE FROM carousel WHERE id = #{id}
    </delete>
</mapper>